CI_ENVIRONMENT = development

app.baseURL = 'http://localhost/enova-admission-app/'
app.forceGlobalSecureRequests = false

database.default.hostname = localhost
database.default.database = admission_db
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

app.sessionDriver    = 'CodeIgniter\Session\Handlers\DatabaseHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration  = 7200
app.sessionSavePath  = 'ci_sessions'
app.sessionMatchIP    = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false

app.CSRFProtection  = true
app.CSRFTokenName   = 'csrf_token'
app.CSRFCookieName  = 'csrf_cookie'
app.CSRFExpire      = 7200
app.CSRFRegenerate  = true
app.CSRFExcludeURIs = []

